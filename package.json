{
  "name": "schichtwerk",
  "private": true,
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "e2e:install": "playwright install chromium",
    "e2e:verify-login": "npm run e2e:verify-login --workspace=@schichtwerk/web",
    "e2e:seed:dashboard": "npm run e2e:seed:dashboard --workspace=@schichtwerk/web",
    "audit:service-role": "node scripts/audit-service-role-key.mjs",
    "dev:web": "npm run dev --workspace=@schichtwerk/web",
    "dev:mobile": "npm run dev --workspace=@schichtwerk/mobile"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/react": "~19.0.10",
    "@types/react-dom": "~19.0.6",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "next": "15.3.6"
  }
}
