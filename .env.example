# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Nur für Server (Web): Einladungen, Admin, Superadmin — NIEMALS in Mobile oder Client bundle
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Kommagetrennte E-Mail-Allowlist — nur diese Accounts sehen Superadmin (lokal + optional Prod)
SUPERADMIN_EMAILS=dev@example.com

# Cron-Auth für /api/cron/* (Vercel Cron: Authorization: Bearer <secret>)
CRON_SECRET=your-cron-secret

# Expo / Mobile (gleiche öffentliche Werte)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
