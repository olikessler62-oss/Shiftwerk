# E2E / Playwright — nach .env.e2e.local kopieren (Repo-Root, NICHT committen)
#
#   copy .env.e2e.example .env.e2e.local
#
# Dieselben Zugangsdaten wie beim manuellen Login unter http://localhost:3000/login
# (Manager- oder Admin-Konto mit Zugriff auf die Gastronomie-Demo).

E2E_MANAGER_EMAIL=deine-manager@email.de
E2E_MANAGER_PASSWORD=dein-passwort

# Optional
# E2E_BASE_URL=http://localhost:3000
# E2E_SKIP_WEB_SERVER=1
